#!/bin/sh
# ----------------------------------------------------------------------------
# Maven Wrapper (script-only, simplified)
# Bootstraps Apache Maven into $HOME/.m2/wrapper/dists on first use.
# ----------------------------------------------------------------------------
set -e

MAVEN_VERSION="3.9.9"
WRAPPER_DIR="${HOME}/.m2/wrapper/dists/apache-maven-${MAVEN_VERSION}-bin"
MAVEN_HOME="${WRAPPER_DIR}/apache-maven-${MAVEN_VERSION}"
DIST_URL="https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/${MAVEN_VERSION}/apache-maven-${MAVEN_VERSION}-bin.zip"
DIST_ZIP="${WRAPPER_DIR}/apache-maven-${MAVEN_VERSION}-bin.zip"

if [ ! -x "${MAVEN_HOME}/bin/mvn" ]; then
    mkdir -p "${WRAPPER_DIR}"
    echo "Downloading Apache Maven ${MAVEN_VERSION}..."
    if command -v curl > /dev/null 2>&1; then
        curl -fsSL -o "${DIST_ZIP}" "${DIST_URL}"
    elif command -v wget > /dev/null 2>&1; then
        wget -q -O "${DIST_ZIP}" "${DIST_URL}"
    else
        echo "Need curl or wget to download Maven." >&2
        exit 1
    fi
    unzip -q "${DIST_ZIP}" -d "${WRAPPER_DIR}"
fi

exec "${MAVEN_HOME}/bin/mvn" "$@"
